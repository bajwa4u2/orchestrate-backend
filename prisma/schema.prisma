model WorkflowRun {
  id                 String          @id @default(cuid())
  organizationId     String
  clientId           String
  subscriptionId     String?
  campaignId         String?
  invoiceId          String?
  serviceAgreementId String?
  statementId        String?
  lane               WorkflowLane
  type               WorkflowType
  status             WorkflowStatus  @default(PENDING)
  trigger            WorkflowTrigger
  source             RecordSource    @default(SYSTEM_GENERATED)
  title              String?
  inputJson          Json?
  contextJson        Json?
  resultJson         Json?
  errorJson          Json?
  startedAt          DateTime?
  completedAt        DateTime?
  failedAt           DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client             Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaigns          Campaign[]
  leadSources        LeadSource[]
  leads              Lead[]
  leadEnrollments    LeadEnrollment[]
  sequences          Sequence[]
  outreachMessages   OutreachMessage[]
  replies            Reply[]
  meetings           Meeting[]
  invoices           Invoice[]
  paymentAttempts    PaymentAttempt[]
  receipts           Receipt[]
  creditNotes        CreditNote[]
  statements         Statement[]
  serviceAgreements  ServiceAgreement[]
  reminderArtifacts  ReminderArtifact[]
  documentDispatches DocumentDispatch[]
  jobRuns            JobRun[]
  activityEvents     ActivityEvent[]
  importBatches      ImportBatch[]

  @@index([organizationId, lane, type, status])
  @@index([clientId, lane, type, status])
  @@index([subscriptionId])
  @@index([campaignId])
  @@index([invoiceId])
  @@index([serviceAgreementId])
  @@index([statementId])
  @@index([createdAt])
}

enum AuthProvider {
  PASSWORD
  GOOGLE
  MICROSOFT
  APPLE
}

model Organization {
  id           String           @id @default(cuid())
  slug         String           @unique
  legalName    String
  displayName  String
  type         OrganizationType @default(CLIENT_ACCOUNT)
  isInternal   Boolean          @default(false)
  isActive     Boolean          @default(true)
  timezone     String?
  countryCode  String?
  currencyCode String           @default("USD")
  metadataJson Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  members                WorkspaceMember[]
  clients                Client[]
  plans                  Plan[]
  subscriptions          Subscription[]
  billingProfiles        BillingProfile[]
  invoices               Invoice[]
  payments               Payment[]
  receipts               Receipt[]
  creditNotes            CreditNote[]
  statements             Statement[]
  collectionActions      CollectionAction[]
  serviceAgreements      ServiceAgreement[]
  reminderArtifacts      ReminderArtifact[]
  documentDispatches     DocumentDispatch[]
  icps                   IdealCustomerProfile[]
  segments               Segment[]
  campaigns              Campaign[]
  sequences              Sequence[]
  leadSources            LeadSource[]
  accounts               Account[]
  contacts               Contact[]
  contactChannels        ContactChannel[]
  contactConsents        ContactConsent[]
  importBatches          ImportBatch[]
  leads                  Lead[]
  outreachMessages       OutreachMessage[]
  replies                Reply[]
  meetings               Meeting[]
  sendingDomains         SendingDomain[]
  mailboxes              Mailbox[]
  sendPolicies           SendPolicy[]
  suppressions           SuppressionEntry[]
  jobs                   Job[]
  activities             ActivityEvent[]
  auditLogs              AuditLog[]
  alerts                 Alert[]
  notes                  Note[]
  templates              Template[]
  policySettings         PolicySetting[]
  clientIndustryProfiles ClientIndustryProfile[]
  extensionRecords       ExtensionRecord[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldValues      CustomFieldValue[]
  pipelineDefinitions    PipelineDefinition[]
  objectStageStates      ObjectStageState[]
  workflowPolicies       WorkflowPolicy[]
  automationRules        AutomationRule[]
  tagDefinitions         TagDefinition[]
  tagAssignments         TagAssignment[]
  invoiceAccessEvents    InvoiceAccessEvent[]
  workflowRuns           WorkflowRun[]
  representationAuths    ClientRepresentationAuth[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String
  passwordHash String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  metadataJson Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  authIdentities     AuthIdentity[]
  memberships        WorkspaceMember[]
  createdClients     Client[]           @relation("ClientCreatedBy")
  createdCampaigns   Campaign[]         @relation("CampaignCreatedBy")
  createdInvoices    Invoice[]          @relation("InvoiceCreatedBy")
  createdStatements  Statement[]        @relation("StatementCreatedBy")
  createdAgreements  ServiceAgreement[] @relation("AgreementCreatedBy")
  createdReminders   ReminderArtifact[] @relation("ReminderCreatedBy")
  createdActivities  ActivityEvent[]    @relation("ActivityActor")
  auditEntries       AuditLog[]         @relation("AuditActor")
  notesAuthored      Note[]             @relation("NoteAuthor")
  alertsResolved     Alert[]            @relation("AlertResolvedBy")
  assignedInquiries  PublicInquiry[]    @relation("InquiryAssignedTo")
  submittedInquiries PublicInquiry[]    @relation("InquirySubmittedByUser")
  inquiryMessages    InquiryMessage[]   @relation("InquiryMessageCreatedBy")
  inquiryNotes       InquiryNote[]      @relation("InquiryNoteAuthor")
}

model AuthIdentity {
  id             String       @id @default(cuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  email          String?
  emailVerified  Boolean      @default(false)
  metadataJson   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider, email])
}

model WorkspaceMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Client {
  id                 String       @id @default(cuid())
  organizationId     String
  createdById        String?
  code               String?
  legalName          String
  displayName        String
  status             ClientStatus @default(LEAD)
  industry           String?
  websiteUrl         String?
  bookingUrl         String?
  primaryTimezone    String?
  currencyCode       String       @default("USD")
  primaryEmail       String?
  billingEmail       String?
  legalEmail         String?
  opsEmail           String?
  primaryContactName String?
  billingContactName String?
  legalContactName   String?
  opsContactName     String?
  country            String?
  area               String?
  scopeJson          Json?
  selectedPlan       String?
  setupCompletedAt   DateTime?
  outboundOffer      String?
  notesText          String?
  metadataJson       Json?
  isInternal         Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  archivedAt         DateTime?

  organization           Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy              User?                      @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  subscriptions          Subscription[]
  billingProfiles        BillingProfile[]
  invoices               Invoice[]
  payments               Payment[]
  receipts               Receipt[]
  creditNotes            CreditNote[]
  statements             Statement[]
  collectionActions      CollectionAction[]
  serviceAgreements      ServiceAgreement[]
  reminderArtifacts      ReminderArtifact[]
  documentDispatches     DocumentDispatch[]
  icps                   IdealCustomerProfile[]
  segments               Segment[]
  campaigns              Campaign[]
  sequences              Sequence[]
  leadSources            LeadSource[]
  accounts               Account[]
  contacts               Contact[]
  contactChannels        ContactChannel[]
  contactConsents        ContactConsent[]
  importBatches          ImportBatch[]
  leads                  Lead[]
  outreachMessages       OutreachMessage[]
  replies                Reply[]
  meetings               Meeting[]
  sendingDomains         SendingDomain[]
  mailboxes              Mailbox[]
  sendPolicies           SendPolicy[]
  suppressions           SuppressionEntry[]
  jobs                   Job[]
  activities             ActivityEvent[]
  alerts                 Alert[]
  notes                  Note[]
  templates              Template[]
  policySettings         PolicySetting[]
  clientIndustryProfiles ClientIndustryProfile[]
  extensionRecords       ExtensionRecord[]
  customFieldDefinitions CustomFieldDefinition[]
  pipelineDefinitions    PipelineDefinition[]
  workflowPolicies       WorkflowPolicy[]
  automationRules        AutomationRule[]
  tagDefinitions         TagDefinition[]
  invoiceAccessEvents    InvoiceAccessEvent[]
  workflowRuns           WorkflowRun[]
  inquiries              PublicInquiry[]            @relation("InquiryClient")
  representationAuths    ClientRepresentationAuth[]

  @@unique([organizationId, displayName])
  @@index([organizationId, status])
  @@index([organizationId, primaryEmail])
  @@index([organizationId, billingEmail])
  @@index([organizationId, legalEmail])
  @@index([organizationId, selectedPlan])
  @@index([organizationId, setupCompletedAt])
}

model Plan {
  id             String       @id @default(cuid())
  organizationId String
  code           String
  name           String
  description    String?
  amountCents    Int
  currencyCode   String       @default("USD")
  interval       PlanInterval
  isActive       Boolean      @default(true)
  featuresJson   Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([organizationId, code])
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String
  clientId           String
  planId             String?
  externalRef        String?
  status             SubscriptionStatus @default(TRIALING)
  amountCents        Int
  currencyCode       String             @default("USD")
  billingAnchorAt    DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  metadataJson       Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan              Plan?              @relation(fields: [planId], references: [id], onDelete: SetNull)
  invoices          Invoice[]
  serviceAgreements ServiceAgreement[]

  @@index([organizationId, status])
  @@index([clientId, status])
}

model Invoice {
  id                 String             @id @default(cuid())
  organizationId     String
  clientId           String
  subscriptionId     String?
  billingProfileId   String?
  createdById        String?
  workflowRunId      String?
  invoiceNumber      String
  status             InvoiceStatus      @default(DRAFT)
  source             RecordSource       @default(SYSTEM_GENERATED)
  lifecycle          ArtifactLifecycle?
  currencyCode       String             @default("USD")
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  subtotalCents      Int                @default(0)
  discountCents      Int                @default(0)
  taxCents           Int                @default(0)
  totalCents         Int                @default(0)
  amountPaidCents    Int                @default(0)
  balanceDueCents    Int                @default(0)
  issuedAt           DateTime?
  dueAt              DateTime?
  lastSentAt         DateTime?
  viewedAt           DateTime?
  paidAt             DateTime?
  pdfFileKey         String?
  pdfFileUrl         String?
  pdfGeneratedAt     DateTime?
  termsText          String?
  notesText          String?
  metadataJson       Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client             Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscription       Subscription?          @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingProfile     BillingProfile?        @relation(fields: [billingProfileId], references: [id], onDelete: SetNull)
  createdBy          User?                  @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  workflowRun        WorkflowRun?           @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  payments           Payment[]
  lines              InvoiceLine[]
  receipts           Receipt[]
  creditNotes        CreditNote[]
  collectionActions  CollectionAction[]
  statementLinks     StatementInvoiceLink[]
  documentDispatches DocumentDispatch[]
  reminderArtifacts  ReminderArtifact[]
  accessEvents       InvoiceAccessEvent[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status, createdAt])
  @@index([clientId, status, dueAt])
  @@index([workflowRunId])
}

model Payment {
  id             String            @id @default(cuid())
  organizationId String
  clientId       String
  invoiceId      String?
  externalRef    String?
