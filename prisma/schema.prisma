  scheduledAt    DateTime?
  sentAt         DateTime?
  acknowledgedAt DateTime?
  subjectLine    String?
  bodyText       String?
  metadataJson   Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client             Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy          User?              @relation("ReminderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  invoice            Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  agreement          ServiceAgreement?  @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  workflowRun        WorkflowRun?       @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  collectionActions  CollectionAction[]
  documentDispatches DocumentDispatch[]

  @@index([clientId, status, scheduledAt])
  @@index([workflowRunId])
}

model DocumentDispatch {
  id                    String                 @id @default(cuid())
  organizationId        String
  clientId              String?
  templateId            String?
  invoiceId             String?
  statementId           String?
  agreementId           String?
  receiptId             String?
  reminderId            String?
  mailboxId             String?
  workflowRunId         String?
  kind                  TemplateType
  emailCategory         EmailCategory?
  emailEvent            EmailEventType?
  status                DocumentDispatchStatus @default(RENDERED)
  source                RecordSource           @default(SYSTEM_GENERATED)
  dispatchState         DispatchLifecycle?
  deliveryChannel       DeliveryChannel        @default(EMAIL)
  deliveryProvider      EmailDeliveryProvider?
  deliveryMode          EmailDeliveryMode?
  recipientEmail        String?
  recipientName         String?
  fromEmail             String?
  replyToEmail          String?
  subjectLine           String?
  bodyText              String?
  payloadJson           Json?
  transportMetadataJson Json?
  externalMessageId     String?
  failureMessage        String?
  attemptCount          Int                    @default(0)
  renderedAt            DateTime               @default(now())
  lastAttemptAt         DateTime?
  deliveredAt           DateTime?
  failedAt              DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  template     Template?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  invoice      Invoice?          @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  statement    Statement?        @relation(fields: [statementId], references: [id], onDelete: SetNull)
  agreement    ServiceAgreement? @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  receipt      Receipt?          @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  reminder     ReminderArtifact? @relation(fields: [reminderId], references: [id], onDelete: SetNull)
  mailbox      Mailbox?          @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  workflowRun  WorkflowRun?      @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  @@index([organizationId, kind, status])
  @@index([workflowRunId])
}

model PublicInquiry {
  id           String              @id @default(cuid())
  inquiryType  PublicInquiryType
  status       PublicInquiryStatus @default(NEW)
  source       String              @default("public_contact_form")
  name         String
  email        String
  company      String?
  message      String
  metadataJson Json?

  sourceKind        InquirySource      @default(PUBLIC)
  accountType       InquiryAccountType @default(PUBLIC)
  category          InquiryCategory?
  intent            InquiryIntent?
  priority          InquiryPriority    @default(MEDIUM)
  aiConfidence      Decimal?           @db.Decimal(5, 4)
  requiresHuman     Boolean            @default(true)
  shouldAskFollowUp Boolean            @default(false)
  resolvedByAi      Boolean            @default(false)
  aiSummary         String?
  aiSuggestedReply  String?
  aiRawJson         Json?
  followUpStateJson Json?
  sourcePage        String?
  planContext       String?
  tierContext       String?
  intakeSessionId   String?
  dedupeHash        String?

  userId   String?
  clientId String?

  assignedToUserId String?
  assignedAt       DateTime?

  firstResponseDueAt DateTime?
  nextResponseDueAt  DateTime?
  firstRespondedAt   DateTime?
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  lastActivityAt     DateTime?
  escalatedAt        DateTime?
  isEscalated        Boolean   @default(false)

  mailboxId        String?
  externalThreadId String?
  lastSyncedAt     DateTime?

  submittedAt    DateTime  @default(now())
  notifiedAt     DateTime?
  acknowledgedAt DateTime?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  submittedBy User?            @relation("InquirySubmittedByUser", fields: [userId], references: [id], onDelete: SetNull)
  client      Client?          @relation("InquiryClient", fields: [clientId], references: [id], onDelete: SetNull)
  assignedTo  User?            @relation("InquiryAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  mailbox     Mailbox?         @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  messages    InquiryMessage[]
  notes       InquiryNote[]

  @@index([status, submittedAt])
  @@index([email])
  @@index([inquiryType, submittedAt])
  @@index([assignedToUserId, status])
  @@index([mailboxId])
  @@index([externalThreadId])
  @@index([isEscalated, status])
  @@index([lastActivityAt])
  @@index([sourceKind, status, submittedAt])
  @@index([accountType, status, submittedAt])
  @@index([category, priority, status])
  @@index([userId, status, submittedAt])
  @@index([clientId, status, submittedAt])
  @@index([intakeSessionId])
  @@index([dedupeHash])
}

model InquiryMessage {
  id                String                   @id @default(cuid())
  inquiryId         String
  direction         InquiryDirection
  channel           InquiryChannel
  messageType       InquiryMessageType
  authorType        InquiryMessageAuthorType @default(USER)
  visibility        InquiryMessageVisibility @default(PUBLIC_THREAD)
  subjectLine       String?
  bodyText          String
  fromEmail         String?
  toEmail           String?
  ccJson            Json?
  externalMessageId String?
  externalThreadId  String?
  mailboxId         String?
  createdByUserId   String?
  sentAt            DateTime?
  receivedAt        DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  inquiry   PublicInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  mailbox   Mailbox?      @relation(fields: [mailboxId], references: [id], onDelete: SetNull)
  createdBy User?         @relation("InquiryMessageCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([inquiryId, createdAt])
  @@index([mailboxId, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([direction, createdAt])
  @@index([messageType, createdAt])
  @@index([authorType, createdAt])
  @@index([visibility, createdAt])
  @@index([externalMessageId])
  @@index([externalThreadId])
}

model InquiryNote {
  id           String          @id @default(cuid())
  inquiryId    String
  authorUserId String?
  noteType     InquiryNoteType @default(OPERATOR_NOTE)
  bodyText     String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  inquiry PublicInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  author  User?         @relation("InquiryNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([inquiryId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([noteType, createdAt])
}

model OpportunityProfile {
  id                String   @id @default(cuid())
  organizationId    String
  clientId          String
  campaignId        String
  title             String
  opportunityType   String
  targetDescription String?
  geographyScope    Json?
  serviceContext    String?
  offerContext      String?
  exclusions        Json?
  strategyJson      Json?
  status            String   @default("ACTIVE")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([campaignId, status])
  @@index([clientId, status])
  @@index([organizationId, status])
}

model SignalEvent {
  id                   String   @id @default(cuid())
  organizationId       String
  clientId             String
  campaignId           String
  opportunityProfileId String
  signalType           String
  signalSourceType     String
  sourceUrlOrKey       String?
  headlineOrLabel      String?
  detectedAt           DateTime @default(now())
  recencyScore         Decimal? @db.Decimal(5, 2)
  confidenceScore      Decimal? @db.Decimal(5, 2)
  geography            String?
  payloadJson          Json?
  normalizedJson       Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([campaignId, signalType, detectedAt])
  @@index([opportunityProfileId, signalType])
}

model SourcePlan {
  id                   String   @id @default(cuid())
  organizationId       String
  clientId             String
  campaignId           String
  opportunityProfileId String
  planVersion          Int      @default(1)
  sourcePriorityJson   Json?
  fallbackPolicyJson   Json?
  signalRulesJson      Json?
  executionLimitsJson  Json?
  status               String   @default("ACTIVE")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([campaignId, status])
  @@index([opportunityProfileId, status])
}

model SourceRun {
  id                   String    @id @default(cuid())
  organizationId       String
  clientId             String
  campaignId           String
  sourcePlanId         String
  opportunityProfileId String?
  sourceType           String
  startedAt            DateTime  @default(now())
  finishedAt           DateTime?
  status               String    @default("RUNNING")
  resultCount          Int       @default(0)
  acceptedCount        Int       @default(0)
  costUnits            Int       @default(0)
  notesJson            Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([campaignId, sourceType, status])
  @@index([sourcePlanId, status])
}

model DiscoveredEntity {
  id                   String   @id @default(cuid())
  organizationId       String
  clientId             String
  campaignId           String
  sourceRunId          String?
  opportunityProfileId String?
  companyName          String
  personName           String?
  inferredRole         String?
  websiteUrl           String?
  domain               String?
  geography            String?
  sourceEvidenceJson   Json?
  entityConfidence     Decimal? @db.Decimal(5, 2)
  dedupeKey            String
  status               String   @default("DISCOVERED")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([campaignId, dedupeKey])
  @@index([campaignId, status])
  @@index([sourceRunId])
}

model ReachabilityRecord {
  id                 String   @id @default(cuid())
  organizationId     String
  clientId           String
  campaignId         String
  discoveredEntityId String
  domain             String?
  contactPageUrl     String?
  emailCandidate     String?
  emailPattern       String?
  verificationStatus String   @default("UNVERIFIED")
  reachabilityScore  Decimal? @db.Decimal(5, 2)
  suppressionStatus  String?
  notesJson          Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([campaignId, verificationStatus])
  @@index([discoveredEntityId])
  @@index([emailCandidate])
}

model QualificationDecision {
  id                   String   @id @default(cuid())
  organizationId       String
  clientId             String
  campaignId           String
  discoveredEntityId   String
  opportunityProfileId String?
  decision             String
  relevanceScore       Decimal? @db.Decimal(5, 2)
  timelinessScore      Decimal? @db.Decimal(5, 2)
  reachabilityScore    Decimal? @db.Decimal(5, 2)
  valueScore           Decimal? @db.Decimal(5, 2)
  finalScore           Decimal? @db.Decimal(5, 2)
  reasonJson           Json?
  decidedAt            DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([campaignId, decision, decidedAt])
  @@index([discoveredEntityId])
}

model ProviderUsageLog {
  id                   String   @id @default(cuid())
  organizationId       String
  clientId             String
  campaignId           String
  opportunityProfileId String?
  providerName         String
  reason               String
  invocationType       String
  costUnits            Int      @default(0)
  resultCount          Int      @default(0)
  outcomeSummary       String?
  metadataJson         Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([campaignId, providerName, createdAt])
}

model AdaptationDecision {
  id                   String   @id @default(cuid())
  organizationId       String
  clientId             String
  campaignId           String
  opportunityProfileId String?
  triggerType          String
  previousPathJson     Json?
  newPathJson          Json?
  reason               String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([campaignId, triggerType, createdAt])
}
